msgstr "ამოალაგეთ tar/შეკუმშული tar ფაილები"

msgid "Unpack to %s"
msgstr "შეფუთვა %s-ში"

msgid "Unpack to current folder"
msgstr "შეფუთვა მიმდინარე საქაღალდეში"

msgid "unpack zip Files"
msgstr "გახსენით zip ფაილები"

msgid "Unsupported archive type."
msgstr "არქივის ტიპი მხარდაუჭერელია."

msgid "v"
msgstr "ვ"

msgid "View or edit file (if size < 1MB)"
msgstr "ფაილის ნახვა ან რედაქტირება (თუ ზომა < 1 მბ)"

msgid "View or edit this %s script"
msgstr "ამ %s სკრიპტის ნახვა ან რედაქტირება"

msgid "WARNING!"
msgstr "გაფრთხილება!"

msgid "What do you want to play?\n"
msgstr "რისი თამაში გინდა?\n"

msgid "without"
msgstr "გარეშე"

msgid "Yes"
msgstr "დიახ"

msgid "You can set the number of letters from the beginning of the current file name as the text pre-filled into virtual keyboard for easier input via group selection."
msgstr "თქვენ შეგიძლიათ დააყენოთ ასოების რაოდენობა მიმდინარე ფაილის სახელის დასაწყისიდან, როგორც წინასწარ შევსებული ტექსტი ვირტუალურ კლავიატურაზე, ჯგუფის შერჩევის გზით უფრო ადვილად შეყვანისთვის."

msgid "You can set the number of letters from the end of the current file name as the text pre-filled into virtual keyboard for easier input via group selection."
msgstr "თქვენ შეგიძლიათ დააყენოთ ასოების რაოდენობა მიმდინარე ფაილის სახელის ბოლოდან, როგორც წინასწარ შევსებული ტექსტი ვირტუალურ კლავიატურაზე, რათა უფრო ადვილად შეიტანოთ ჯგუფური შერჩევის გზით."

msgid "You can set what will group selection use - start of title, end of title or contains in title."
msgstr "შეგიძლიათ დააყენოთ რას გამოიყენებს ჯგუფური შერჩევა - სათაურის დასაწყისი, სათაურის დასასრული ან შეიცავს სათაურში."

